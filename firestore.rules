rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Catálogo público de versões bíblicas para download
    match /bible_versions/{versionId} {
      allow read: if true;
      allow write: if false;
    }

    // Dados do utilizador autenticado (sync de favoritos, notas, progresso)
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Compatibilidade com esquema legado (coleções no topo com userId)
    match /favorites/{docId} {
      allow read, write: if request.auth != null && (
        resource.data.userId == request.auth.uid ||
        request.resource.data.userId == request.auth.uid
      );
    }

    match /notes/{docId} {
      allow read, write: if request.auth != null && (
        resource.data.userId == request.auth.uid ||
        request.resource.data.userId == request.auth.uid
      );
    }

    match /reading_progress/{docId} {
      allow read, write: if request.auth != null && (
        resource.data.userId == request.auth.uid ||
        request.resource.data.userId == request.auth.uid
      );
    }

    match /favorite_blocks/{docId} {
      allow read, write: if request.auth != null && (
        resource.data.userId == request.auth.uid ||
        request.resource.data.userId == request.auth.uid
      );
    }

    match /hymn_favorites/{docId} {
      allow read, write: if request.auth != null && (
        resource.data.userId == request.auth.uid ||
        request.resource.data.userId == request.auth.uid
      );
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
